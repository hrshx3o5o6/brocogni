{
  "name": "browser-cognition-mcp",
  "version": "1.0.6",
  "description": "Brocogni -- Making Playwright make sense to AI agents. MCP server for semantic browser observation and self-healing selectors.",
  "type": "module",
  "bin": {
    "browser-cognition-mcp": "dist/src/runtime/mcp.js"
  },
  "files": [
    "dist/src/",
    "README.md",
    "LICENSE",
    "opencode.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/src/runtime/mcp.js",
    "configure": "node bin/configure.js",
    "test": "npm run build && node --test 'dist/test/**/*.test.js'"
  },
  "keywords": [
    "brocogni",
    "mcp",
    "model-context-protocol",
    "playwright",
    "browser-automation",
    "accessibility-tree",
    "self-healing-selectors",
    "ai-agents"
  ],
  "author": "Harsha",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hrshx3o5o6/brocogni.git"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "playwright": "^1.54.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
